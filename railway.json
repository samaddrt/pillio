{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "docker build -t pillio:latest ."
  },
  "deploy": {
    "startCommand": "./pillio",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindow": 600
  },
  "env": {
    "API_PORT": "8080",
    "STORAGE_PATH": "/app/data/store.json",
    "FAMILY_STORAGE_PATH": "/app/data/family.json"
  }
}
