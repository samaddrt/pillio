run = "bash start.sh"
entrypoint = "src/main.cpp"

[deployment]
build = ["sh", "-c", "mkdir -p build && g++ -std=c++20 -O2 -I src -I third_party src/main.cpp src/tracker.cpp src/storage.cpp src/analytics.cpp src/checker.cpp src/family.cpp -o build/pillio -lpthread 2>&1 && pip install -q -r bot/requirements.txt 2>/dev/null || true"]
run = ["sh", "-c", "./build/pillio & PYTHONPATH=/tmp/pylibs python3 bot/bot.py & wait"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[env]
API_PORT = "8080"
STORAGE_PATH = "/tmp/store.json"
FAMILY_STORAGE_PATH = "/tmp/family.json"
BOT_TOKEN = "8696800857:AAGFoxyRUdPTyDallFvvbAV6QS56i31mlOw"
WEBAPP_URL = "https://pillio-dodoevsamad1.replit.app"
API_URL = "http://localhost:8080"
