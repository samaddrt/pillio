run = "mkdir -p build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Release && make -j$(nproc) && cd .. && ./build/pillio"
entrypoint = "src/main.cpp"

[deployment]
run = ["sh", "-c", "mkdir -p build && cd build && cmake .. -DCMAKE_BUILD_TYPE=Release && make -j$(nproc) && cd .. && ./build/pillio"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[env]
API_PORT = "8080"
STORAGE_PATH = "/tmp/store.json"
FAMILY_STORAGE_PATH = "/tmp/family.json"
