# API Configuration
API_PORT=8080

# Storage paths (Railway uses /app/data/)
STORAGE_PATH=/app/data/store.json
FAMILY_STORAGE_PATH=/app/data/family.json

# Telegram Bot Token (get from BotFather)
BOT_TOKEN=your_bot_token_here

# API and webapp URLs (for bot)
# On Railway, the domain will be auto-generated like: pillio-prod.up.railway.app
API_URL=https://your-railway-domain.up.railway.app
WEBAPP_URL=https://your-railway-domain.up.railway.app
